# Local dev only — copy to ".env.development.local" (gitignored).
# Use when ports 8000 (API) and/or 5173 (Vite) are already taken.
#
#   cp .env.development.example .env.development.local
#
# Then start the API on the SAME port as VITE_API_PORT, e.g.:
#   cd ../api && python3.11 -m uvicorn main:app --host 127.0.0.1 --port 8001

VITE_API_PORT=8001
VITE_DEV_PORT=5174
