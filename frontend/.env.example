# Production (GitHub Actions / local preview): API origin, no trailing slash
# VITE_API_BASE_URL=https://your-api.onrender.com

# GitHub Pages project site base (must end with /)
# VITE_BASE_PATH=/BayesianHeartDisease/

# Local dev: API port for Vite proxy (see vite.config.ts)
# VITE_API_PORT=8001   # only if API is not on default 8000
